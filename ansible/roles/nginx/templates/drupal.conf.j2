server {
    listen 80;
    server_name _;

    root {{ drupal_root }};
    index index.php index.html;

    # Maximum upload size
    client_max_body_size 32M;

    # Drupal clean URLs
    location / {
        try_files $uri /index.php?$query_string;
    }

    # Block access to hidden files (e.g. .htaccess)
    location ~ /\. {
        deny all;
    }

    # Block access to sensitive Drupal files
    location ~ ^/sites/.*/private/ {
        return 403;
    }

    location ~ ^/sites/[^/]+/files/.*\.php$ {
        deny all;
    }

    # Block access to PHP files in certain directories
    location ~* ^(?:.+\.(?:htaccess|make|txt|engine|inc|info|install|module|profile|po|sh|.*sql|theme|tpl(?:\.php)?|xtmpl)|code-style\.pl|/Makefile|README)$ {
        return 403;
    }

    # Pass PHP requests to PHP-FPM
    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/var/run/php/php8.2-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_read_timeout 60;
    }

    # Cache static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 30d;
        add_header Cache-Control "public, no-transform";
        try_files $uri @rewrite;
    }

    location @rewrite {
        rewrite ^ /index.php;
    }

    # Gzip compression
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
}
